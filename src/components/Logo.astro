---
// src/components/Logo.astro
interface Props {
  className?: string;
  showText?: boolean;
}

const { className = "", showText = true } = Astro.props;
---

<div class={`flex items-center gap-2.5 ${className}`}>
  <!-- Logo Icon -->
  <div class="relative flex items-center justify-center w-10 h-10 shrink-0">
    <!-- Outer Glow/Shadow -->
    <div class="absolute inset-0 bg-blue-600/20 blur-lg rounded-xl"></div>
    
    <!-- Main Icon Shape -->
    <div class="relative w-full h-full bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl shadow-lg flex items-center justify-center overflow-hidden border border-blue-400/30">
      <!-- Decorative Element -->
      <div class="absolute -top-2 -right-2 w-8 h-8 bg-white/10 rounded-full blur-md"></div>
      
      <!-- Code Brackets -->
      <svg 
        xmlns="http://www.w3.org/2000/svg" 
        width="22" 
        height="22" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="white" 
        stroke-width="2.5" 
        stroke-linecap="round" 
        stroke-linejoin="round"
        class="drop-shadow-sm"
      >
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
    </div>
  </div>

  {showText && (
    <div class="flex flex-col -space-y-1">
      <span class="text-xl font-black tracking-tight text-slate-900">
        Pak<span class="text-blue-600">Koding</span>
      </span>
      <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest pl-0.5">
        Edukasi Teknologi
      </span>
    </div>
  )}
</div>
