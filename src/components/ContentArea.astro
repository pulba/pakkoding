---
// src/components/ContentArea.astro
import { type Lesson } from "../data/lessons";
import CodeBlock from "./CodeBlock.astro";
import LivePreview from "./LivePreview.astro";

interface Props {
  lesson: Lesson;
  prevLessonId?: string | null;
  nextLessonId?: string | null;
}

const { lesson, prevLessonId, nextLessonId } = Astro.props;

const getPillColor = (category: string) => {
  switch (category) {
    case "HTML":
      return "bg-orange-100 text-orange-600";
    case "CSS":
      return "bg-sky-100 text-sky-600";
    case "JS":
      return "bg-yellow-100 text-yellow-700";
    case "Koding":
      return "bg-emerald-100 text-emerald-600";
    case "AI":
      return "bg-indigo-100 text-indigo-600";
    default:
      return "bg-slate-100 text-slate-600";
  }
};
---

<div
  class="flex-1 max-w-5xl mx-auto px-6 md:px-12 py-12 md:py-16"
  id="lesson-content"
  data-lesson-id={lesson.id}
>
  <header class="mb-8">
    <div
      class="flex flex-col md:flex-row md:items-start justify-between gap-8 mb-6"
    >
      <div class="flex-1">
        <div
          class={`inline-block px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider mb-6 ${getPillColor(lesson.category)}`}
        >
          {lesson.category}
        </div>
        <h1
          class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-6"
        >
          {lesson.title}
        </h1>
        <p class="text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl">
          {lesson.description}
        </p>
      </div>
    </div>
  </header>

  <div class="space-y-24">
    {
      lesson.content.map((section) => (
        <section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
          {section.image && (
            <div class="mb-10 rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
              <img 
                src={section.image} 
                alt={`Diagram ${lesson.title}`} 
                class="w-full h-auto object-cover"
              />
            </div>
          )}
          <div class="mb-12">
            <details open class="group bg-white border border-slate-200 rounded-2xl overflow-hidden transition-all duration-300 open:shadow-lg open:ring-1 open:ring-blue-100">
              <summary class="flex items-center justify-between p-5 cursor-pointer list-none hover:bg-slate-50 transition-colors">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center group-open:bg-blue-600 group-open:text-white transition-all">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                      </>
                    </svg>
                  </div>
                  <span class="font-bold text-slate-700">
                    Penjelasan Lengkap
                  </span>
                </div>
                <div class="text-slate-400 group-open:rotate-180 transition-transform duration-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </div>
              </summary>

              <div class="p-6 pt-2 border-t border-slate-50">
                <div class="text-base md:text-lg text-slate-600 leading-relaxed space-y-2">
                  {section.explanation.split("\n").map((line) => {
                    const trimmedLine = line.trim();
                    if (!trimmedLine) return null;

                    // Parse bolding (replace **text** with <strong>text</strong>)
                    const parts = trimmedLine
                      .split(/(\*\*.*?\*\*)/g)
                      .map((part) => {
                        if (part.startsWith("**") && part.endsWith("**")) {
                          return (
                            <strong class="text-slate-900 font-bold">
                              {part.slice(2, -2)}
                            </strong>
                          );
                        }
                        return part;
                      });

                    if (trimmedLine.startsWith("- ")) {
                      return (
                        <div class="flex gap-3 pl-2 py-1">
                          <span class="text-blue-500 font-black mt-1.5 text-xs">
                            •
                          </span>
                          <span>{parts.slice(1)}</span>
                        </div>
                      );
                    }

                    return <p>{parts}</p>;
                  })}
                </div>
              </div>
            </details>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
            <div class="space-y-4">
              <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">
                Contoh Kode
              </div>
              <CodeBlock code={section.code} />
            </div>
            <div class="space-y-4">
              <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 ml-1">
                Hasil Tampilan
              </div>
              <LivePreview code={section.code} />
            </div>
          </div>

          <div class="mt-12 border-y border-slate-100 bg-slate-50/50 -mx-4 md:-mx-12 px-4 md:px-12">
            <div class="max-w-3xl mx-auto">
              <div class="flex items-center gap-2 mb-8">
                <div class="w-8 h-8 bg-blue-600 text-white rounded-lg flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                      <polyline points="14 2 14 8 20 8" />
                    </>
                  </svg>
                </div>
                <span class="text-xs font-black text-blue-600 uppercase tracking-widest">
                  Tugas Praktik (Pertanyaan)
                </span>
              </div>

              <h2 class="text-xl md:text-2xl font-bold text-slate-800 leading-snug mb-6">
                {section.challenge ||
                  "Tantangan: Coba praktikkan kode di atas di VS Code!"}
              </h2>


            </div>
          </div>
        </section>
      ))
    }
  </div>

  <div class="mt-4 flex justify-center">
    <button
      id="toggle-complete-btn"
      class="flex items-center gap-2 px-5 py-2.5 rounded-lg font-bold text-sm transition-all duration-300 shadow-md shadow-blue-100 hover:shadow-blue-200 shrink-0 bg-blue-600 text-white hover:bg-blue-700 outline-none"
    >
      <div id="status-icon-todo">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg
        >
      </div>
      <div id="status-icon-done" class="hidden">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
            points="22 4 12 14.01 9 11.01"></polyline></svg
        >
      </div>
      <span id="status-text">Selesai</span>
    </button>
  </div>

  <nav
    class="mt-12 border-t border-slate-200 flex flex-col sm:flex-row items-center justify-between gap-4"
    aria-label="Navigasi Pelajaran"
  >
    {
      prevLessonId ? (
        <a
          href={`/materi/${prevLessonId}`}
          class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-bold transition-all duration-200 bg-white text-slate-700 ring-1 ring-slate-200 hover:bg-slate-50 outline-none"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Kembali
        </a>
      ) : (
        <div class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-bold bg-slate-50 text-slate-300 ring-1 ring-slate-100 cursor-not-allowed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Kembali
        </div>
      )
    }

    {
      nextLessonId ? (
        <a
          href={`/materi/${nextLessonId}`}
          class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-bold transition-all duration-200 bg-blue-600 text-white hover:bg-blue-700 shadow-lg shadow-blue-100 outline-none"
        >
          Lanjut Belajar
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </a>
      ) : (
        <div class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-bold bg-slate-50 text-slate-300 ring-1 ring-slate-100 cursor-not-allowed">
          Lanjut Belajar
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      )
    }
  </nav>
</div>

<script>
  function setupLessonCompletion() {
    const lessonContent = document.getElementById("lesson-content");
    const lessonId = lessonContent?.getAttribute("data-lesson-id");
    const toggleBtn = document.getElementById("toggle-complete-btn");
    const iconTodo = document.getElementById("status-icon-todo");
    const iconDone = document.getElementById("status-icon-done");
    const statusText = document.getElementById("status-text");

    if (!lessonId || !toggleBtn) return;

    function getCompleted() {
      const savedUser = localStorage.getItem("gurucode_current_user");
      const currentUser = savedUser ? JSON.parse(savedUser) : null;
      if (currentUser) return currentUser.completedLessons || [];
      const saved = localStorage.getItem("gurucode_completed");
      return saved ? JSON.parse(saved) : [];
    }

    function setCompleted(list) {
      const savedUser = localStorage.getItem("gurucode_current_user");
      const currentUser = savedUser ? JSON.parse(savedUser) : null;
      if (currentUser) {
        currentUser.completedLessons = list;
        localStorage.setItem(
          "gurucode_current_user",
          JSON.stringify(currentUser),
        );

        // Also update in global users list
        const users = JSON.parse(
          localStorage.getItem("gurucode_users") || "[]",
        );
        const updatedUsers = users.map((u) =>
          u.email === currentUser.email ? { ...u, completedLessons: list } : u,
        );
        localStorage.setItem("gurucode_users", JSON.stringify(updatedUsers));
      } else {
        localStorage.setItem("gurucode_completed", JSON.stringify(list));
      }

      // Notify other components
      window.dispatchEvent(new CustomEvent("progress-updated"));
    }

    function updateUI() {
      const list = getCompleted();
      const isCompleted = list.includes(lessonId);

      if (isCompleted) {
        toggleBtn.classList.remove(
          "bg-blue-600",
          "hover:bg-blue-700",
          "text-white",
        );
        toggleBtn.classList.add(
          "bg-emerald-50",
          "text-emerald-700",
          "ring-1",
          "ring-emerald-200",
          "hover:bg-emerald-100",
        );
        iconTodo?.classList.add("hidden");
        iconDone?.classList.remove("hidden");
        if (statusText) statusText.textContent = "Selesai";
      } else {
        toggleBtn.classList.add(
          "bg-blue-600",
          "hover:bg-blue-700",
          "text-white",
        );
        toggleBtn.classList.remove(
          "bg-emerald-50",
          "text-emerald-700",
          "ring-1",
          "ring-emerald-200",
          "hover:bg-emerald-100",
        );
        iconTodo?.classList.remove("hidden");
        iconDone?.classList.add("hidden");
        if (statusText) statusText.textContent = "Selesai";
      }
    }

    toggleBtn.addEventListener("click", () => {
      let list = getCompleted();
      if (list.includes(lessonId)) {
        list = list.filter((id) => id !== lessonId);
      } else {
        list.push(lessonId);
      }
      setCompleted(list);
      updateUI();
    });

    updateUI();
  }

  setupLessonCompletion();
</script>
