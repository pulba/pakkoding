---
// src/components/ContentArea.astro
import { type CollectionEntry } from "astro:content";
import CodeBlock from "./CodeBlock.astro";
import LivePreview from "./LivePreview.astro";

type Lesson = { id: string } & CollectionEntry<"materi">["data"];

interface Props {
  lesson: Lesson;
  prevLessonId?: string | null;
  nextLessonId?: string | null;
}

const { lesson, prevLessonId, nextLessonId } = Astro.props;

const getPillColor = (category: string) => {
  switch (category) {
    case "HTML":
      return "bg-orange-100 text-orange-600";
    case "CSS":
      return "bg-sky-100 text-sky-600";
    case "JS":
      return "bg-yellow-100 text-yellow-700";
    case "Koding":
      return "bg-emerald-100 text-emerald-600";
    case "AI":
    case "Prompting":
      return "bg-indigo-100 text-indigo-600";
    default:
      return "bg-slate-100 text-slate-600";
  }
};
---

<div
  class="flex-1 max-w-5xl mx-auto px-6 md:px-12 py-12 md:py-16"
  id="lesson-content"
  data-lesson-id={lesson.id}
>
  <header class="mb-12">
    <div
      class="flex flex-col md:flex-row md:items-start justify-between gap-8 mb-6"
    >
      <div class="flex-1">
        <div
          class={`inline-block px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider mb-8 ${getPillColor(lesson.category)}`}
        >
          {lesson.category}
        </div>
        <h1
          class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white tracking-tighter leading-[1] mb-8"
        >
          {lesson.title}
        </h1>
        <p
          class="text-xl md:text-2xl text-slate-500 dark:text-slate-400 leading-relaxed max-w-3xl"
        >
          {lesson.description}
        </p>
      </div>
    </div>
  </header>

  <div class="space-y-20">
    {
      lesson.content.map((section) => (
        <section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
          {section.image && (
            <div class="mb-10 rounded-2xl overflow-hidden border border-slate-200 shadow-sm">
              <img
                src={section.image}
                alt={`Diagram ${lesson.title}`}
                class="w-full h-auto object-cover"
              />
            </div>
          )}
          <div class="mb-12">
            <details
              open
              class="group bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[1.5rem] overflow-hidden shadow-sm"
            >
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                <div class="flex items-center gap-4">
                  <div class="text-2xl">🎯</div>
                  <span class="font-bold text-lg text-slate-800 dark:text-slate-100">
                    Penjelasan Lengkap
                  </span>
                </div>
                <div class="text-slate-400 group-open:rotate-180 transition-transform duration-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </div>
              </summary>

              <div class="px-6 pb-8 pt-2 border-t border-slate-100 dark:border-slate-800">
                <div class="text-base md:text-[1.05rem] text-slate-700 dark:text-slate-300 leading-relaxed space-y-4">
                  {section.explanation.split("\n").map((line) => {
                    const trimmedLine = line.trim();
                    if (!trimmedLine) return null;

                    // Detect Mini Challenge
                    if (trimmedLine.includes("🏆 Mini Challenge")) {
                      return (
                        <div class="my-8 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 rounded-2xl p-6">
                          <div class="flex items-center gap-2 mb-3">
                            <span class="text-lg">🏆</span>
                            <span class="text-sm font-bold text-blue-700 dark:text-blue-400 uppercase tracking-widest">
                              Mini Challenge (Bonus)
                            </span>
                          </div>
                          <p class="text-slate-700 dark:text-slate-300 italic">
                            {trimmedLine
                              .replace("**🏆 Mini Challenge**", "")
                              .trim() ||
                              "Selesaikan tantangan kecil ini untuk menguji pemahamanmu!"}
                          </p>
                        </div>
                      );
                    }

                    // Parse bolding
                    const parts = trimmedLine
                      .split(/(\*\*.*?\*\*)/g)
                      .map((part) => {
                        if (part.startsWith("**") && part.endsWith("**")) {
                          return (
                            <strong class="text-slate-900 dark:text-white font-bold">
                              {part.slice(2, -2)}
                            </strong>
                          );
                        }
                        return part;
                      });

                    // Subheading detection (if entire line is bold)
                    if (
                      trimmedLine.startsWith("**") &&
                      trimmedLine.endsWith("**") &&
                      !trimmedLine.includes(" ", 40)
                    ) {
                      return (
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white pt-4 pb-2">
                          {parts}
                        </h3>
                      );
                    }

                    if (trimmedLine.startsWith("- ")) {
                      const partsCopy = [...parts];
                      if (
                        partsCopy.length > 0 &&
                        typeof partsCopy[0] === "string"
                      ) {
                        partsCopy[0] = partsCopy[0].substring(2);
                      }
                      return (
                        <div class="flex gap-3 pl-2 py-1">
                          <span class="text-blue-500 font-black mt-1.5 text-xs">
                            •
                          </span>
                          <span>{partsCopy}</span>
                        </div>
                      );
                    }

                    return <p>{parts}</p>;
                  })}
                </div>
              </div>
            </details>
          </div>

          <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-12">
            <div class="space-y-4">
              <div class="text-sm font-bold text-slate-700 dark:text-slate-300 flex items-center gap-2 mb-2">
                <span class="text-lg">💻</span> Contoh Kode / Formula Prompt
              </div>
              <CodeBlock code={section.code} />
            </div>
            <div class="space-y-4">
              <div class="text-sm font-bold text-slate-700 dark:text-slate-300 flex items-center gap-2 mb-2">
                <span class="text-lg">✨</span> Hasil Tampilan / Simulasi AI
              </div>
              <div class="bg-blue-50/50 dark:bg-slate-800/50 border border-dashed border-blue-200 dark:border-slate-700 rounded-2xl p-6 h-full min-h-[200px] flex items-center justify-center">
                <div class="w-full">
                  <LivePreview code={section.code} />
                </div>
              </div>
            </div>
          </div>

          <div class="mb-12 bg-yellow-50 dark:bg-yellow-900/20 border-l-[6px] border-yellow-400 rounded-r-2xl p-6 md:p-8">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xl">📝</span>
              <span class="text-xs font-black text-yellow-800 dark:text-yellow-500 uppercase tracking-widest">
                Tugas Praktik (Pertanyaan)
              </span>
            </div>
            <h2 class="text-sm font-bold text-slate-800 dark:text-slate-200 leading-snug">
              {section.challenge ||
                "Tantangan: Coba praktikkan kode di atas di VS Code!"}
            </h2>
          </div>
        </section>
      ))
    }
  </div>

  <div class="mt-4 flex justify-center">
    <button
      id="toggle-complete-btn"
      class="flex items-center gap-2 px-5 py-2 rounded-lg font-bold text-xs transition-all duration-300 shadow-md shrink-0 bg-blue-600 text-white hover:bg-blue-700 outline-none"
    >
      <div id="status-icon-todo">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg
        >
      </div>
      <div id="status-icon-done" class="hidden">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
            points="22 4 12 14.01 9 11.01"></polyline></svg
        >
      </div>
      <span id="status-text">Selesai</span>
    </button>
  </div>

  <nav
    class="mt-16 border-t border-slate-200 dark:border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    aria-label="Navigasi Pelajaran"
  >
    {
      prevLessonId ? (
        <a
          href={`/materi/${prevLessonId}`}
          class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-full font-bold transition-all duration-200 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Kembali ke Pilih Materi
        </a>
      ) : (
        <div class="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 rounded-full font-bold bg-slate-50 dark:bg-slate-800/50 text-slate-400 dark:text-slate-600 border border-slate-100 dark:border-slate-800 cursor-not-allowed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Kembali ke Pilih Materi
        </div>
      )
    }

    <!-- Kategori Badge -->
    <div
      class="hidden md:flex items-center justify-center px-6 py-2 border border-slate-200 dark:border-slate-700 rounded-full font-bold text-sm text-slate-500 bg-white dark:bg-slate-900"
    >
      📄 {lesson.category}
    </div>

    {
      nextLessonId ? (
        <a
          href={`/materi/${nextLessonId}`}
          class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-3 rounded-full font-bold transition-all duration-200 bg-blue-600 text-white hover:bg-blue-700 hover:shadow-lg hover:-translate-y-0.5 outline-none"
        >
          Lanjut Belajar
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </a>
      ) : (
        <div class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-3 rounded-full font-bold bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-600 cursor-not-allowed">
          Lanjut Belajar
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      )
    }
  </nav>
</div>

<script>
  function setupLessonCompletion() {
    const lessonContent = document.getElementById("lesson-content");
    const lessonId = lessonContent?.getAttribute("data-lesson-id");
    const toggleBtn = document.getElementById("toggle-complete-btn");
    const iconTodo = document.getElementById("status-icon-todo");
    const iconDone = document.getElementById("status-icon-done");
    const statusText = document.getElementById("status-text");

    if (!lessonId || !toggleBtn) return;

    const STORAGE_KEY = "pakkoding-completed-lessons";

    function getCompletedList(): string[] {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
      } catch {
        return [];
      }
    }

    function saveCompletedList(list: string[]) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    }

    let completedList = getCompletedList();

    function updateUI() {
      const isCompleted = completedList.includes(lessonId as string);

      if (isCompleted) {
        toggleBtn?.classList.remove(
          "bg-blue-600",
          "hover:bg-blue-700",
          "text-white",
        );
        toggleBtn?.classList.add(
          "bg-emerald-50",
          "text-emerald-700",
          "ring-1",
          "ring-emerald-200",
          "hover:bg-emerald-100",
        );
        iconTodo?.classList.add("hidden");
        iconDone?.classList.remove("hidden");
        if (statusText) statusText.textContent = "Selesai";
      } else {
        toggleBtn?.classList.add(
          "bg-blue-600",
          "hover:bg-blue-700",
          "text-white",
        );
        toggleBtn?.classList.remove(
          "bg-emerald-50",
          "text-emerald-700",
          "ring-1",
          "ring-emerald-200",
          "hover:bg-emerald-100",
        );
        iconTodo?.classList.remove("hidden");
        iconDone?.classList.add("hidden");
        if (statusText) statusText.textContent = "Selesai";
      }

      // Notify Sidebar and Topbar progress
      window.dispatchEvent(
        new CustomEvent("progress-updated", { detail: { completedList } }),
      );
    }

    toggleBtn.addEventListener("click", () => {
      const isCurrentlyCompleted = completedList.includes(lessonId as string);

      if (!isCurrentlyCompleted) {
        completedList.push(lessonId as string);
      } else {
        completedList = completedList.filter((id) => id !== lessonId);
      }

      saveCompletedList(completedList);
      updateUI();
    });

    updateUI();
  }

  setupLessonCompletion();
</script>
