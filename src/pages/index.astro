---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="flex-1 flex flex-col items-center justify-center p-6 text-center max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight">
      Selamat Datang di <span class="text-blue-600">Pak Koding</span>
    </h1>
    <p class="text-lg md:text-xl text-slate-600 mb-12 leading-relaxed">
      Platform belajar pemrograman web paling santai dan mudah dipahami. 
      Mulai perjalananmu menjadi developer profesional dari nol.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-4xl mt-4">
      <!-- Card 1: Web Dev -->
      <a 
        href="/kurikulum#web-dev"
        class="group cursor-pointer bg-white p-8 rounded-2xl border-2 border-slate-200 hover:border-blue-500 hover:shadow-xl transition-all duration-300 w-full relative overflow-hidden text-left flex flex-col h-full"
      >
        <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 mb-6 group-hover:scale-110 transition-transform shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Belajar Dasar Pemrograman Web</h2>
        <p class="text-slate-500 mb-8 flex-grow">Kuasai HTML, CSS, dan JavaScript dalam satu jalur pembelajaran terpadu untuk membangun website.</p>
        
        <div class="flex items-center text-blue-600 font-bold gap-2 group-hover:gap-4 transition-all mt-auto">
          Mulai Sekarang <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
      </a>

      <!-- Card 2: Koding & AI -->
      <a 
        href="/kurikulum#ai"
        class="group cursor-pointer bg-white p-8 rounded-2xl border-2 border-slate-200 hover:border-indigo-500 hover:shadow-xl transition-all duration-300 w-full relative overflow-hidden text-left flex flex-col h-full"
      >
        <div class="w-16 h-16 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 mb-6 group-hover:scale-110 transition-transform shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path><line x1="8" y1="16" x2="8" y2="16"></line><line x1="16" y1="16" x2="16" y2="16"></line></svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Koding dan Kecerdasan Artifisial</h2>
        <p class="text-slate-500 mb-8 flex-grow">Pahami fundamental koding dan selami dunia Artificial Intelligence, Machine Learning, hingga NLP.</p>
        
        <div class="flex items-center text-indigo-600 font-bold gap-2 group-hover:gap-4 transition-all mt-auto">
          Mulai Sekarang <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </div>
      </a>
    </div>
  </div>
</Layout>
