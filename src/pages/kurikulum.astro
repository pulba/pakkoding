---
// src/pages/kurikulum.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pilih Materi - Pak Koding">
  <div class="flex-1 p-6 md:p-12 max-w-6xl mx-auto w-full">
    <a 
      href="/"
      class="flex items-center gap-2 text-slate-500 hover:text-slate-900 mb-8 font-medium transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Kembali ke Home
    </a>
    
    <h2 class="text-3xl font-bold text-slate-900 mb-2">Pilih Materi Belajar</h2>
    <p class="text-slate-500 mb-12">Klik salah satu teknologi di bawah ini untuk mulai mempelajari materinya.</p>
    
    <!-- Section 1: Web Development -->
    <div id="web-dev" class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900">Dasar Pemrograman Web</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { id: 'Tools', title: 'Persiapan', desc: 'Pengenalan dan alat koding.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg', firstLesson: 'persiapan-belajar' },
          { id: 'HTML', title: 'HTML', desc: 'Struktur dasar halaman web.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg', firstLesson: 'html-intro' },
          { id: 'CSS', title: 'CSS', desc: 'Desain dan tata letak visual.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg', firstLesson: 'css-intro' },
          { id: 'JS', title: 'JavaScript', desc: 'Logika dan interaktivitas.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg', firstLesson: 'js-intro' }
        ].map((cat) => (
          <a 
            href={`/materi/${cat.firstLesson}`}
            class="group cursor-pointer bg-white p-8 rounded-2xl border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1"
          >
            <div class="w-16 h-16 mb-6">
              <img src={cat.logo} alt={`Logo ${cat.title}`} class="w-full h-full object-contain drop-shadow-sm group-hover:scale-110 transition-transform duration-300" />
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">{cat.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{cat.desc}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- Section 2: Koding & AI -->
    <div id="ai">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path><line x1="8" y1="16" x2="8" y2="16"></line><line x1="16" y1="16" x2="16" y2="16"></line></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900">Koding & Kecerdasan Artifisial</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { id: 'Koding', title: 'Dasar Koding', desc: 'Konsep dasar pemrograman, algoritma, dan logika berpikir komputer.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/thealgorithms/thealgorithms-original.svg', firstLesson: 'koding-intro' },
          { id: 'AI', title: 'Artificial Intelligence', desc: 'Mengenal AI, Machine Learning, Deep Learning, dan penerapannya.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tensorflow/tensorflow-original.svg', firstLesson: 'ai-definisi' }
        ].map((cat) => (
          <a 
            href={`/materi/${cat.firstLesson}`}
            class="group cursor-pointer bg-white p-8 rounded-2xl border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1"
          >
            <div class="w-16 h-16 mb-6">
              <img src={cat.logo} alt={`Logo ${cat.title}`} class="w-full h-full object-contain drop-shadow-sm group-hover:scale-110 transition-transform duration-300" />
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">{cat.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{cat.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

