---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
---

<Layout title="Kurikulum - Pak Koding">
  <div class="flex-1 p-6 md:p-12 max-w-6xl mx-auto w-full py-16 animate-in fade-in duration-700">
    <div class="mb-12">
      <a 
        href="/"
        class="inline-flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 mb-8 font-bold transition-all hover:-translate-x-1 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-[-2px] transition-transform"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Kembali ke Beranda
      </a>
      
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white mb-6 tracking-tighter">Kurikulum <span class="text-blue-600 dark:text-blue-400">Belajar</span></h1>
      <p class="text-lg md:text-xl text-slate-500 dark:text-slate-400 max-w-3xl leading-relaxed">Dari nol sampai bisa. Ikuti alur belajar yang sudah kami susun rapi untuk membantumu menguasai teknologi modern secara bertahap.</p>
    </div>
    
    <!-- Section 1: Web Development -->
    <div id="web-dev" class="mb-20">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-blue-200 dark:shadow-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </div>
        <h2 class="text-2xl font-black text-slate-900 dark:text-white">Dasar Pemrograman Web</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        {[
          { id: 'Tools', title: 'Persiapan', desc: 'Pengenalan & instalasi alat koding.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg', firstLesson: 'persiapan-belajar' },
          { id: 'HTML', title: 'HTML5', desc: 'Pondasi struktur website.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg', firstLesson: 'html-intro' },
          { id: 'CSS', title: 'CSS3 Modern', desc: 'Gaya & tata letak visual.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg', firstLesson: 'css-intro' },
          { id: 'JS', title: 'JavaScript', desc: 'Logika & fitur interaktif.', logo: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg', firstLesson: 'js-intro' }
        ].map((cat, idx) => (
          <a 
            href={`/materi/${cat.firstLesson}`}
            class={`group cursor-pointer bg-white/70 dark:bg-slate-900/50 backdrop-blur-sm p-4 md:p-8 rounded-3xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 hover:shadow-2xl transition-all duration-500 hover:-translate-y-1 flex md:flex-col items-center md:items-start gap-4 md:gap-0 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-[${idx * 100}ms]`}
          >
            <div class="w-12 h-12 md:w-16 md:h-16 md:mb-8 bg-white dark:bg-slate-800 rounded-2xl p-2.5 md:p-3 shadow-sm border border-slate-100 dark:border-slate-700 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shrink-0 flex items-center justify-center overflow-hidden">
              <Image src={cat.logo} alt={`Logo ${cat.title}`} width={64} height={64} class="w-full h-full object-contain" />
            </div>
            <div class="flex-1">
              <h3 class="text-base md:text-xl font-bold text-slate-900 dark:text-white mb-1 md:mb-3">{cat.title}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-xs md:text-sm leading-relaxed mb-3 md:mb-6">{cat.desc}</p>
              <div class="text-blue-600 dark:text-blue-400 text-[10px] md:text-xs font-black uppercase tracking-widest flex items-center gap-1 md:gap-2">
                Mulai <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Section 2: Koding & AI -->
    <div id="ai" class="pb-16">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-indigo-200 dark:shadow-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path></svg>
        </div>
        <h2 class="text-2xl font-black text-slate-900 dark:text-white">Koding & Kecerdasan Artifisial</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'HTML Dasar', category: 'HTML', desc: 'Belajar struktur dasar halaman web dari nol.', lessons: 8, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg' },
          { title: 'CSS Modern', category: 'CSS', desc: 'Mempercantik tampilan web dengan CSS Grid & Flexbox.', lessons: 12, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/css3/css3-original.svg' },
          { title: 'JavaScript Dasar', category: 'JS', desc: 'Menambahkan logika dan interaktivitas pada website.', lessons: 15, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg' },
          { title: 'VS Code & Git', category: 'Tools', desc: 'Penguasaan alat koding dan version control.', lessons: 5, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg' },
          { title: 'Algoritma', category: 'Koding', desc: 'Logika pemrograman dan penyelesaian masalah.', lessons: 10, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/thealgorithms/thealgorithms-original.svg' },
          { title: 'Intro to AI', category: 'AI', desc: 'Dasar kecerdasan buatan dan implementasi sederhana.', lessons: 6, icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tensorflow/tensorflow-original.svg' }
        ].map((item) => (
          <a 
            href="/kurikulum" 
            class="group bg-white dark:bg-slate-900/50 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 transition-all hover:shadow-2xl hover:-translate-y-1"
          >
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-slate-50 dark:bg-slate-800 rounded-2xl p-3 flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-transform overflow-hidden">
                <Image src={item.icon} alt={item.title} width={40} height={40} class="w-full h-full object-contain" />
              </div>
              <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-[10px] font-black uppercase tracking-widest rounded-full border border-blue-100 dark:border-blue-800">
                {item.category}
              </span>
            </div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{item.title}</h3>
            <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed mb-6">{item.desc}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-slate-400">{item.lessons} Materi</span>
              <div class="w-8 h-8 rounded-full bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
