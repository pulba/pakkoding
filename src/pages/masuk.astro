---
// src/pages/masuk.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Masuk - Pak Koding">
  <div class="flex-1 flex items-center justify-center p-6 min-h-[80vh]">
    <div class="w-full max-w-md bg-white rounded-3xl border border-slate-200 p-8 shadow-xl shadow-slate-200/50">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 text-blue-600 rounded-xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <h2 class="text-2xl font-black text-slate-900">Selamat Datang Kembali</h2>
        <p class="text-slate-500 text-sm mt-2">Masuk untuk melanjutkan perjalanan belajar Anda dengan aman.</p>
      </div>

      <div class="space-y-4">
        <div id="error-message" class="hidden p-3 bg-red-50 text-red-600 text-sm rounded-lg border border-red-100 mb-4"></div>

        <button 
          id="google-login-btn"
          class="w-full bg-white border-2 border-slate-200 text-slate-700 py-3 rounded-xl font-bold hover:bg-slate-50 hover:border-blue-200 transition-all flex items-center justify-center gap-3 relative"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span id="btn-text">Masuk dengan Google</span>
          <div id="loader" class="hidden absolute right-4 animate-spin text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
          </div>
        </button>
      </div>

      <div class="mt-8 pt-6 border-t border-slate-100 text-center">
        <p class="text-sm text-slate-500">
          Dengan masuk, Anda menyetujui syarat & ketentuan.
        </p>
      </div>
    </div>
  </div>

  <script>
    import { auth, googleProvider, signInWithPopup } from '../lib/firebase-client';

    const loginBtn = document.getElementById('google-login-btn') as HTMLButtonElement;
    const errorMsg = document.getElementById('error-message');
    const loader = document.getElementById('loader');

    loginBtn?.addEventListener('click', async () => {
      if (!errorMsg || !loginBtn || !loader) return;

      errorMsg.classList.add('hidden');
      loginBtn.disabled = true;
      loader.classList.remove('hidden');

      try {
        const result = await signInWithPopup(auth, googleProvider);
        const idToken = await result.user.getIdToken();

        // Kirim ID Token ke server
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ idToken })
        });

        if (response.ok) {
          // Redirect ke halaman utama jika sukses
          window.location.href = '/';
        } else {
          const data = await response.json();
          throw new Error(data.error || 'Login gagal di server');
        }

      } catch (error: any) {
        console.error("Login Error:", error);
        errorMsg.textContent = error.message || 'Gagal masuk dengan Google.';
        errorMsg.classList.remove('hidden');
        loginBtn.disabled = false;
        loader.classList.add('hidden');
      }
    });
  </script>
</Layout>
