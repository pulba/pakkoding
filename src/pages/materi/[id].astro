---
// src/pages/materi/[id].astro
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";
import ContentArea from "../../components/ContentArea.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allMateri = await getCollection("materi");
  allMateri.sort((a, b) => a.data.order - b.data.order);

  return allMateri.map((entry, index) => {
    const prevLessonId = index > 0 ? allMateri[index - 1].id : null;
    const nextLessonId =
      index < allMateri.length - 1 ? allMateri[index + 1].id : null;
    return {
      params: { id: entry.id },
      props: {
        lesson: { id: entry.id, ...entry.data },
        prevLessonId,
        nextLessonId,
        totalLessons: allMateri.length,
      },
    };
  });
}

const { lesson, prevLessonId, nextLessonId, totalLessons } = Astro.props;
---

<Layout title={`${lesson.title} - Pak Koding`} description={lesson.description}>
  <div class="bg-slate-100/50 dark:bg-slate-950/80 min-h-screen">
    <div class="">
      <!-- Learning Shell Wrapper -->
      <div class="bg-white dark:bg-slate-900 flex flex-col">
        <!-- Body Shell (Sidebar + Content) -->
        <div class="flex flex-col md:flex-row flex-1">
          <!-- Sidebar Section -->
          <div
            class="w-full md:w-72 lg:w-80 shrink-0 border-r border-slate-100 dark:border-slate-800 bg-slate-50/30 dark:bg-slate-900/30"
          >
            <Sidebar
              activeLessonId={lesson.id}
              selectedCategory={lesson.category}
            />
          </div>

          <!-- Main Content Area -->
          <main class="flex-1 min-w-0 flex flex-col">
            <div class="px-6 md:px-12 pt-8 flex justify-end">
              <!-- Progress Indicator -->
              <div
                class="flex items-center gap-3 bg-white dark:bg-slate-800 px-5 py-2.5 rounded-full border border-slate-200 dark:border-slate-700 shadow-sm"
                id="lesson-progress-container"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-emerald-500"
                  ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
                    points="22 4 12 14.01 9 11.01"></polyline></svg
                >
                <div class="flex flex-col min-w-[140px]">
                  <div
                    class="flex justify-between text-[10px] font-bold text-slate-500 dark:text-slate-400"
                  >
                    <span class="uppercase tracking-widest">Progress</span>
                    <span
                      id="lesson-progress-text"
                      class="text-slate-800 dark:text-slate-200">0%</span
                    >
                  </div>
                  <div
                    class="w-full h-1.5 bg-slate-100 dark:bg-slate-700 rounded-full mt-1.5 overflow-hidden"
                  >
                    <div
                      id="lesson-progress-bar"
                      class="h-full bg-emerald-500 transition-all duration-500 ease-out"
                      style="width: 0%"
                    >
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <ContentArea
              lesson={lesson}
              prevLessonId={prevLessonId}
              nextLessonId={nextLessonId}
            />
          </main>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ totalLessons }}>
    function updateProgress(completedLessons) {
      const progressText = document.getElementById("lesson-progress-text");
      const progressBar = document.getElementById("lesson-progress-bar");

      const completedCount = (completedLessons || []).length;
      const progressPercentage = Math.round(
        (completedCount / totalLessons) * 100,
      );

      if (progressText)
        progressText.textContent = `${completedCount}/${totalLessons} (${progressPercentage}%)`;
      if (progressBar) progressBar.style.width = `${progressPercentage}%`;
    }

    // Listen for updates from ContentArea or Sidebar
    window.addEventListener("progress-updated", (e) => {
      if (e.detail && e.detail.completedList) {
        updateProgress(e.detail.completedList);
      }
    });
  </script>
</Layout>
