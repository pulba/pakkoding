---
import Layout from '../layouts/Layout.astro';
import { faqData } from '../data/faq';
import { Image } from 'astro:assets';
import faqIllustration from '../assets/faq_illustration.png';
---

<Layout title="FAQ - Pak Koding">
  <div class="flex-1 max-w-7xl mx-auto w-full py-12 md:py-24 px-6 animate-in fade-in duration-1000">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left Side: Illustration -->
      <div class="hidden lg:block relative sticky top-32">
        <div class="absolute -inset-20 bg-blue-50/50 dark:bg-blue-900/20 rounded-full blur-3xl opacity-50 -z-10"></div>
        <Image 
          src={faqIllustration} 
          alt="FAQ Illustration" 
          class="w-full h-auto object-contain transform hover:scale-105 transition-transform duration-1000"
        />
      </div>

      <!-- Right Side: Content -->
      <div class="flex flex-col">
        <div class="mb-12">
          <div class="flex items-center gap-4 mb-4">
            <a href="/" class="text-blue-600 dark:text-blue-400 font-bold text-sm hover:underline">FAQ</a>
            <span class="text-slate-300 dark:text-slate-600">/</span>
            <span class="text-slate-500 dark:text-slate-400 text-sm tracking-widest">HELP CENTER</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-8 tracking-tight">Frequently Asked Questions</h1>
          <p class="text-lg text-slate-500 dark:text-slate-400 mb-8">Punya pertanyaan seputar perjalanan belajarmu? Kami merangkum jawaban terbaik untuk membantumu melangkah lebih jauh.</p>
        </div>

        <!-- Accordion Section -->
        <div class="flex flex-col gap-3">
          {faqData.map((item, index) => (
            <div 
              class="faq-item group bg-white dark:bg-slate-900/50 border border-slate-100 dark:border-slate-800 rounded-2xl transition-all duration-300 hover:border-blue-200 dark:hover:border-blue-800 hover:shadow-xl hover:shadow-slate-100/50 dark:hover:shadow-none"
            >
              <button
                class="faq-toggle w-full flex items-center justify-between p-6 text-left focus:outline-none"
              >
                <span class="text-lg font-bold text-slate-700 dark:text-slate-200 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-tight">{item.question}</span>
                <div class="chevron-icon relative w-6 h-6 shrink-0 transition-transform duration-500">
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-4 h-0.5 bg-slate-400 dark:bg-slate-600 rounded-full"></div>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center rotate-90 vertical-line transition-transform duration-500">
                    <div class="w-4 h-0.5 bg-slate-400 dark:bg-slate-600 rounded-full"></div>
                  </div>
                </div>
              </button>
              
              <div class="faq-content max-h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out">
                <div class="px-6 pb-6 text-base text-slate-500 dark:text-slate-400 leading-relaxed">
                  {item.answer}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.faq-item').forEach(item => {
      const toggle = item.querySelector('.faq-toggle');
      const content = item.querySelector('.faq-content');
      const verticalLine = item.querySelector('.vertical-line');

      toggle?.addEventListener('click', () => {
        const isOpen = content?.classList.contains('max-h-[500px]');
        
        // Close others
        document.querySelectorAll('.faq-content').forEach(c => {
          c.classList.remove('max-h-[500px]', 'opacity-100');
          c.classList.add('max-h-0', 'opacity-0');
        });
        document.querySelectorAll('.vertical-line').forEach(vl => {
          vl.classList.remove('rotate-0');
          vl.classList.add('rotate-90');
        });

        if (!isOpen) {
          content?.classList.remove('max-h-0', 'opacity-0');
          content?.classList.add('max-h-[500px]', 'opacity-100');
          verticalLine?.classList.remove('rotate-90');
          verticalLine?.classList.add('rotate-0');
        }
      });
    });
  </script>
</Layout>
